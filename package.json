{
  "name": "mhio-web-analytics",
  "version": "0.0.1",
  "description": "API-first open source website analyzer for SEO, content flow, and UX heuristics.",
  "type": "module",
  "main": "backend/dist/server.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "tsx watch backend/src/server.ts",
    "dev:web": "vite",
    "build": "npm run build:api && npm run build:web",
    "build:api": "tsc -p backend/tsconfig.json",
    "build:web": "vite build",
    "start": "node backend/dist/server.js",
    "test": "vitest run --config vitest.config.ts"
  },
  "author": "Martin-Andree Herz",
  "license": "Apache-2.0",
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@tabler/icons-react": "^3.41.1",
    "cheerio": "^1.2.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^9.2.1",
    "node-mocks-http": "^1.17.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^7.3.2",
    "vitest": "^4.1.4"
  }
}
