# Copy this file to `.env` and adjust the values for your environment.
# All values below are optional unless noted otherwise.

# -----------------------------------------------------------------------------
# Application / Server
# -----------------------------------------------------------------------------

# Host interface for the HTTP server.
# Default: 0.0.0.0
HOST=0.0.0.0

# Port for the HTTP server.
# Default: 3000
PORT=3000

# Runtime environment.
# Common values: development, test, production
# Default: development
NODE_ENV=development

# Enable or disable the Swagger UI and OpenAPI endpoints.
# true  -> /docs and /openapi.json are exposed
# false -> docs endpoints are not mounted
# Default: true
MHIO_DOCS_ENABLED=true

# -----------------------------------------------------------------------------
# HTTP / Fetching
# -----------------------------------------------------------------------------

# Custom User-Agent used for page fetches and internal link validation.
# You can set your company, product name, version, and contact URL here.
# Default: mhio-web-analytics/0.0.1 (+https://github.com/)
MHIO_HTTP_USER_AGENT=mhio-web-analytics/0.0.1 (+https://github.com/your-org/your-repo)

# Timeout in milliseconds for regular HTTP requests.
# Default: 10000
MHIO_HTTP_TIMEOUT_MS=10000

# Whether redirects should be followed when fetching pages.
# true  -> follow redirects automatically
# false -> expose redirect responses as-is where possible
# Default: true
MHIO_HTTP_FOLLOW_REDIRECTS=true

# -----------------------------------------------------------------------------
# Crawl Behaviour
# -----------------------------------------------------------------------------

# Default page limit for site crawls when the request does not send `maxPages`.
# Default: 10
MHIO_CRAWLER_DEFAULT_MAX_PAGES=10

# Hard upper limit for `maxPages` accepted by the API.
# This protects the service from unexpectedly huge crawls.
# Default: 50
MHIO_CRAWLER_HARD_MAX_PAGES=50

# Parallel crawl workers for site analysis.
# Higher values can speed up crawling but increase target load.
# Default: 3
MHIO_CRAWLER_CONCURRENCY=3

# HTTP method for broken internal link checks.
# Recommended values: HEAD or GET
# Some websites do not support HEAD correctly. In that case switch to GET.
# Default: HEAD
MHIO_BROKEN_LINK_CHECK_METHOD=HEAD

# -----------------------------------------------------------------------------
# PageSpeed / Performance
# -----------------------------------------------------------------------------

# Enable PageSpeed lookups by default even when the API request does not
# explicitly send `includePerformance`.
# Default: false
MHIO_PAGESPEED_DEFAULT_ENABLED=false

# Default PageSpeed strategy.
# Allowed values: mobile, desktop
# Default: mobile
MHIO_PAGESPEED_STRATEGY=mobile

# Timeout in milliseconds for PageSpeed API requests.
# Default: 20000
MHIO_PAGESPEED_TIMEOUT_MS=20000

# Optional Google PageSpeed Insights API key.
# Leave empty to use unauthenticated requests.
# In production it is recommended to set a key to improve reliability.
PAGESPEED_API_KEY=

# -----------------------------------------------------------------------------
# Future / Optional placeholders
# -----------------------------------------------------------------------------

# Reserved examples for later extensions. Keep them commented out until needed.

# Enable more verbose crawl logging in future versions
# MHIO_LOG_LEVEL=info

# Custom contact email for crawler identification
# MHIO_HTTP_CONTACT_EMAIL=seo@example.com

# Potential future allowlist for crawl origins
# MHIO_CRAWLER_ALLOWED_HOSTS=example.com,www.example.com
